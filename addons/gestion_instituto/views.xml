<odoo>
    <record id="view_ciclo_form" model="ir.ui.view">
        <field name="name">instituto.ciclo.form</field>
        <field name="model">instituto.ciclo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group><field name="name"/></group>
                    <notebook>
                        <page string="Módulos del Ciclo">
                            <field name="modulo_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_modulo_form" model="ir.ui.view">
        <field name="name">instituto.modulo.form</field>
        <field name="model">instituto.modulo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="ciclo_id"/>
                        <field name="profesor_id"/>
                    </group>
                    <notebook>
                        <page string="Alumnos Matriculados">
                            <field name="alumno_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_instituto_ciclo" model="ir.actions.act_window">
        <field name="name">Ciclos Formativos</field>
        <field name="res_model">instituto.ciclo</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_instituto_modulo" model="ir.actions.act_window">
        <field name="name">Módulos</field>
        <field name="res_model">instituto.modulo</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_instituto_alumno" model="ir.actions.act_window">
        <field name="name">Alumnos</field>
        <field name="res_model">instituto.alumno</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_instituto_profesor" model="ir.actions.act_window">
        <field name="name">Profesores</field>
        <field name="res_model">instituto.profesor</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_instituto_root" name="Gestión Instituto"/>
    <menuitem id="menu_instituto_ciclos" parent="menu_instituto_root" action="action_instituto_ciclo" sequence="1"/>
    <menuitem id="menu_instituto_modulos" parent="menu_instituto_root" action="action_instituto_modulo" sequence="2"/>
    <menuitem id="menu_instituto_alumnos" parent="menu_instituto_root" action="action_instituto_alumno" sequence="3"/>
    <menuitem id="menu_instituto_profesores" parent="menu_instituto_root" action="action_instituto_profesor" sequence="4"/>
</odoo>