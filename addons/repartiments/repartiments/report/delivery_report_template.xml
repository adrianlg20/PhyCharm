<odoo>
    <template id="delivery_report_template">
        <t t-call="web.basic_layout">
            <div class="page">
                <h2>Repartiments Pendents</h2>
                <t t-foreach="docs" t-as="employee">
                    <h3><t t-esc="employee.name"/></h3>
                    <t t-foreach="employee.delivery_ids.filtered(lambda d: d.state=='no_eixit')" t-as="d">
                        <p>
                            <t t-esc="d.code"/> - 
                            <t t-esc="d.reception_date"/>
                        </p>
                    </t>
                </t>
            </div>
        </t>
    </template>
</odoo>