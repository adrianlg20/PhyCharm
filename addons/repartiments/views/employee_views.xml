<odoo>
    <record id="view_employee_tree" model="ir.ui.view">
        <field name="name">sg.employee.tree</field>
        <field name="model">sg.employee</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="carnet_moto"/>
                <field name="carnet_furgo"/>
            </tree>
        </field>
    </record>

    <record id="action_employee" model="ir.actions.act_window">
        <field name="name">Empleats</field>
        <field name="res_model">sg.employee</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>